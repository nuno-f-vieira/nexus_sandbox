/* ── MARKET INTELLIGENCE WIDGET ── */
.news-section{
  background:linear-gradient(160deg,#0a1520 0%,#0d1e2e 100%);
  padding:4rem 3.5rem;
  border-top:3px solid var(--blue);
  border-bottom:3px solid var(--blue);
  position:relative;
}
.news-section::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,var(--blue),var(--blue2),var(--blue),transparent);
}
.news-inner{max-width:1200px;margin:0 auto}

/* ── CAROUSEL ── */
.news-carousel{
  position:relative;display:flex;align-items:center;
  gap:1rem;margin-top:2.5rem;
}
.news-carousel-arrow{
  flex-shrink:0;width:44px;height:44px;
  background:rgba(36,120,200,0.12);border:1px solid var(--border2);
  color:var(--blue2);font-size:20px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  transition:all 0.2s;user-select:none;z-index:2;
}
.news-carousel-arrow:hover{background:var(--blue);border-color:var(--blue);color:#fff}
.news-carousel-arrow:disabled{opacity:0.25;cursor:default;pointer-events:none}
.news-carousel-track{
  flex:1;display:grid;grid-template-columns:1fr 1.2fr 1fr;
  gap:1px;background:rgba(90,179,245,0.1);overflow:hidden;
}
/* centre card gets emphasis */
.news-card{
  background:rgba(21,31,46,0.85);
  padding:1.75rem;
  display:flex;flex-direction:column;gap:0.6rem;
  text-decoration:none;transition:background 0.25s,transform 0.25s;
  cursor:pointer;
}
.news-card:hover{background:rgba(28,42,58,0.95)}
.news-card.center{
  background:rgba(26,74,122,0.25);
  border-left:2px solid var(--blue2);border-right:2px solid var(--blue2);
}
.news-card.center:hover{background:rgba(26,74,122,0.4)}
.news-card.side{opacity:0.7}
.news-card.side:hover{opacity:1}
.news-card-tag{
  font-size:9.5px;letter-spacing:0.14em;text-transform:uppercase;
  color:var(--blue2);font-weight:700;
  background:rgba(90,179,245,0.1);
  display:inline-block;padding:2px 7px;width:fit-content;
}
.news-card-title{
  font-size:13px;color:var(--textd);line-height:1.65;font-weight:400;
}
.news-card.center .news-card-title{font-size:14.5px;font-weight:500}
.news-card-source{
  font-size:11px;color:var(--muted);margin-top:auto;padding-top:0.75rem;
  border-top:1px solid rgba(90,179,245,0.1);
  display:flex;justify-content:space-between;align-items:center;
}
.news-card-cta{
  font-size:10px;color:var(--blue2);letter-spacing:0.06em;
  text-transform:uppercase;opacity:0;transition:opacity 0.2s;
}
.news-card:hover .news-card-cta{opacity:1}
.news-carousel-dots{
  display:flex;justify-content:center;gap:8px;margin-top:1.25rem;
}
.news-dot{
  width:6px;height:6px;border-radius:50%;
  background:var(--border2);cursor:pointer;transition:all 0.2s;
}
.news-dot.active{background:var(--blue2);width:18px;border-radius:3px}
.news-card-loading{
  grid-column:1/-1;background:rgba(21,31,46,0.85);padding:2rem;
  display:flex;align-items:center;justify-content:center;
  color:var(--muted);font-size:12px;
}
@media(max-width:960px){.news-carousel-track{grid-template-columns:1fr 1fr}}
@media(max-width:580px){.news-carousel-track{grid-template-columns:1fr}}
.modal-overlay{
  position:fixed;inset:0;z-index:500;
  background:rgba(7,15,26,0.88);
  display:flex;align-items:center;justify-content:center;
  padding:2rem 1.25rem;
  opacity:0;pointer-events:none;
  transition:opacity 0.25s ease;
  backdrop-filter:blur(6px);
}
.modal-overlay.open{opacity:1;pointer-events:auto}
.modal-box{
  background:var(--bg2);
  border:1px solid var(--border2);
  max-width:720px;width:100%;
  max-height:82vh;display:flex;flex-direction:column;
  position:relative;
}
.modal-header{
  display:flex;align-items:center;justify-content:space-between;
