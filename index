<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nexus Advisory Group</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#151f2e;
  --bg2:#1c2a3a;
  --bg3:#223244;
  --blue:#2478c8;
  --blue2:#5ab3f5;
  --blue3:#8dceff;
  --muted:#6b8aa6;
  --muted2:#96b8d0;
  --text:#ccdde8;
  --textd:#eaf4ff;
  --border:rgba(90,179,245,0.14);
  --border2:rgba(90,179,245,0.28);
}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);line-height:1.7;overflow-x:hidden;font-size:15px}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:200;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 3.5rem;height:66px;
  background:rgba(21,31,46,0.97);
  border-bottom:1px solid var(--border);
  backdrop-filter:blur(24px);
}
.nav-logo{cursor:pointer;display:flex;align-items:center;gap:10px;text-decoration:none;flex-shrink:0}
.nav-gif{height:42px;width:auto;mix-blend-mode:screen;display:block;flex-shrink:0}
.nav-logo-word{font-family:'DM Sans',sans-serif;font-size:18px;font-weight:600;color:var(--textd);letter-spacing:0.12em;white-space:nowrap}
.nav-logo-sub{font-size:9px;letter-spacing:0.18em;color:var(--muted);text-transform:uppercase;margin-top:1px;white-space:nowrap}
nav ul{list-style:none;display:flex;gap:2.5rem}
nav ul a{
  color:var(--muted2);text-decoration:none;font-size:13px;
  letter-spacing:0.06em;font-weight:400;cursor:pointer;
  transition:color 0.2s;text-transform:uppercase;
}
nav ul a:hover,nav ul a.active{color:var(--textd)}
.nav-cta{
  font-size:12px;letter-spacing:0.1em;text-transform:uppercase;
  padding:9px 22px;border:1px solid var(--blue2);
  color:var(--blue2);background:transparent;cursor:pointer;
  transition:all 0.25s;font-family:'Inter',sans-serif;font-weight:500;
}
.nav-cta:hover{background:var(--blue);border-color:var(--blue);color:#fff}

/* ── MARKET TICKER ── */
.market-ticker{
  position:fixed;top:66px;left:0;right:0;z-index:190;
  background:var(--bg2);border-bottom:1px solid var(--border);
  height:38px;display:flex;align-items:center;overflow:hidden;
}
/* scroll offset for fixed bars (nav 66 + market 38 + services 38 = 142) */
.sec,.sec-alt,.sec-alt-inner,section{scroll-margin-top:150px}
.ticker-label{
  font-size:10px;letter-spacing:0.16em;text-transform:uppercase;
  color:var(--blue2);padding:0 1.25rem;white-space:nowrap;
  border-right:1px solid var(--border);background:var(--bg2);
  height:100%;display:flex;align-items:center;z-index:2;flex-shrink:0;
}
.ticker-scroll{flex:1;overflow:hidden;position:relative}
.ticker-track{
  display:flex;gap:0;white-space:nowrap;
  transition:none;
}
.ticker-item{
  display:inline-flex;align-items:center;gap:0.5rem;
  font-size:12px;padding:0 1.75rem;
  border-right:1px solid var(--border);height:38px;
  font-weight:400;
}
.ticker-sym{color:var(--muted2);font-size:11px;letter-spacing:0.05em;font-weight:500}
.ticker-price{color:var(--textd);font-weight:500}
.ticker-change.up{color:#3dd68c}
.ticker-change.down{color:#f06060}
.ticker-change.flat{color:var(--muted2)}

/* ── HERO ── */
.hero{
  min-height:100vh;display:flex;align-items:center;
  padding:0 3.5rem;padding-top:158px;position:relative;overflow:hidden;
}
.hero-grid-bg{
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(74,163,240,0.035) 1px,transparent 1px),
    linear-gradient(90deg,rgba(74,163,240,0.035) 1px,transparent 1px);
  background-size:72px 72px;
  mask-image:radial-gradient(ellipse 75% 65% at 55% 45%,black,transparent);
  pointer-events:none;
}
.hero-glow{
  position:absolute;top:-10%;right:-5%;
  width:700px;height:700px;
  background:radial-gradient(circle,rgba(31,111,191,0.1) 0%,transparent 68%);
  pointer-events:none;
}
.hero-inner{max-width:1200px;margin:0 auto;width:100%;display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:center;position:relative;z-index:1}
.hero-eyebrow{
  display:inline-flex;align-items:center;gap:10px;
  font-size:11px;letter-spacing:0.18em;text-transform:uppercase;
  color:var(--blue2);margin-bottom:2rem;font-weight:500;
}
.hero-eyebrow::before{content:'';width:28px;height:1px;background:var(--blue2)}
.hero h1{
  font-family:'DM Sans',sans-serif;
  font-size:clamp(2rem,3.2vw,3rem);
  font-weight:600;line-height:1.05;
  color:var(--textd);margin-bottom:1.25rem;
  letter-spacing:-0.025em;
}
.hero h1 .accent{
  background:linear-gradient(135deg,var(--blue2) 0%,var(--blue3) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.hero-sub{
  font-size:1.05rem;color:var(--muted2);line-height:1.85;
  max-width:460px;margin-bottom:2.5rem;font-weight:400;
}
.hero-actions{display:flex;gap:1rem;flex-wrap:wrap}
.btn-primary{
  padding:14px 30px;background:var(--blue);color:#fff;
  font-size:13px;font-weight:500;letter-spacing:0.07em;
  text-transform:uppercase;border:none;cursor:pointer;
  font-family:'Inter',sans-serif;transition:all 0.25s;
}
.btn-primary:hover{background:var(--blue2);color:var(--bg)}
.btn-ghost{
  padding:14px 30px;background:transparent;
  border:1px solid var(--border2);color:var(--blue2);
  font-size:13px;font-weight:400;letter-spacing:0.07em;
  text-transform:uppercase;cursor:pointer;
  font-family:'Inter',sans-serif;transition:all 0.25s;
}
.btn-ghost:hover{border-color:var(--blue2);background:rgba(74,163,240,0.06)}
.hero-visual{display:flex;align-items:center;justify-content:flex-start;padding-left:1rem}
.hero-logo-box{
  background:transparent;
  border:1px solid var(--border2);
  padding:0;
  display:flex;align-items:center;justify-content:center;
  position:relative;overflow:hidden;
}
.hero-logo-box::before{
  content:'';position:absolute;
  top:-1px;left:2rem;right:2rem;height:1px;
  background:linear-gradient(90deg,transparent,var(--blue2),transparent);
  z-index:1;
}
.hero-logo-box::after{
  content:'';position:absolute;
  bottom:-1px;left:2rem;right:2rem;height:1px;
  background:linear-gradient(90deg,transparent,var(--blue2),transparent);
  z-index:1;
}
.hero-logo-box img{width:100%;max-width:460px;height:auto;mix-blend-mode:screen;display:block}

/* ── SECTIONS ── */
.sec{padding:7rem 3.5rem;max-width:1200px;margin:0 auto}
.sec-alt{background:var(--bg2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.sec-alt-inner{padding:7rem 3.5rem;max-width:1200px;margin:0 auto}
.eyebrow{
  font-size:11px;letter-spacing:0.2em;text-transform:uppercase;
  color:var(--blue2);margin-bottom:0.9rem;
  display:flex;align-items:center;gap:10px;font-weight:500;
}
.eyebrow::before{content:'';width:20px;height:1px;background:var(--blue2)}
h2{
  font-family:'DM Sans',sans-serif;
  font-size:clamp(1.6rem,2.6vw,2.2rem);
  font-weight:600;color:var(--textd);
  letter-spacing:-0.02em;line-height:1.12;
}
h3{font-size:1rem;font-weight:500;color:var(--textd);letter-spacing:0.01em}
.lead{font-size:1.05rem;color:var(--muted2);line-height:1.85;max-width:600px;margin-top:1rem}

/* ── ABOUT ── */
.about-cols{display:grid;grid-template-columns:1.1fr 0.9fr;gap:5rem;align-items:start;margin-top:3.5rem}
.about-body p{color:var(--muted2);font-size:0.97rem;line-height:1.9;margin-bottom:1.1rem}
.stat-row{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);margin-top:2.5rem;border:1px solid var(--border)}
.stat-box{background:var(--bg);padding:1.75rem 1.5rem;text-align:center}
.stat-num{font-family:'DM Sans',sans-serif;font-size:2.2rem;font-weight:600;color:var(--textd)}
.stat-num span{color:var(--blue2)}
.stat-lbl{font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);margin-top:6px}
.values-stack{display:flex;flex-direction:column;gap:1px;background:var(--border)}
.vrow{background:var(--bg);padding:1.3rem 1.5rem;display:flex;gap:1.1rem;align-items:flex-start;transition:background 0.2s;cursor:default}
.vrow:hover{background:var(--bg3)}
.vbar{width:2px;background:var(--blue2);flex-shrink:0;align-self:stretch;min-height:44px;margin-top:2px}
.vtitle{font-size:14px;font-weight:500;color:var(--textd);margin-bottom:4px}
.vdesc{font-size:13px;color:var(--muted2);line-height:1.65}

/* ── SERVICES ROLLING STRIP (inline page element) ── */
.svc-strip{
  position:fixed;top:104px;left:0;right:0;z-index:170;
  background:var(--bg);
  border-bottom:1px solid var(--border);
  height:38px;display:flex;align-items:center;overflow:hidden;
}
.strip-label{
  font-size:10px;letter-spacing:0.16em;text-transform:uppercase;
  color:var(--blue2);padding:0 1.25rem;white-space:nowrap;
  border-right:1px solid var(--border);height:100%;
  display:flex;align-items:center;flex-shrink:0;font-weight:500;
}
.strip-scroll{flex:1;overflow:hidden}
.strip-track{
  display:inline-flex;white-space:nowrap;
  animation:stripScroll 50s linear infinite;
}
.strip-track:hover{animation-play-state:paused}
@keyframes stripScroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.news-ticker-item{
  font-size:11.5px;color:var(--muted2);padding:0 2rem;
  height:38px;display:inline-flex;align-items:center;gap:8px;
  border-right:1px solid var(--border);white-space:nowrap;
  text-decoration:none;transition:color 0.2s;cursor:pointer;
}
.news-ticker-item:hover{color:var(--textd)}
.news-ticker-tag{
  font-size:9px;color:var(--blue2);letter-spacing:0.1em;
  text-transform:uppercase;font-weight:600;flex-shrink:0;
  background:rgba(90,179,245,0.08);padding:2px 6px;border-radius:2px;
}
.news-ticker-source{
  font-size:9.5px;color:var(--muted);font-style:italic;flex-shrink:0;
}
.news-ticker-sep{
  color:var(--border2);font-size:10px;flex-shrink:0;
}
.strip-item{
  font-size:11px;letter-spacing:0.12em;text-transform:uppercase;
  color:var(--muted2);padding:0 2.25rem;
  border-right:1px solid var(--border);height:38px;
  display:inline-flex;align-items:center;
  transition:color 0.2s;
}
.strip-item:hover{color:var(--blue2)}

/* ── SERVICE CARD HOVER OVERLAY ── */
.svc-overlay{
  position:absolute;inset:0;
  background:linear-gradient(160deg,rgba(10,22,36,0.98) 0%,rgba(16,36,58,0.99) 100%);
  display:flex;flex-direction:column;justify-content:flex-start;
  padding:1.6rem 1.75rem;
  opacity:0;transform:translateY(8px);
  transition:opacity 0.28s ease,transform 0.28s ease;
  pointer-events:none;z-index:10;
}
.svc:hover .svc-overlay{opacity:1;transform:translateY(0);pointer-events:auto}
.svc-overlay-title{
  font-size:11px;letter-spacing:0.14em;text-transform:uppercase;
  color:var(--blue2);margin-bottom:0.5rem;font-weight:600;
}
.svc-overlay-desc{
  font-size:12px;color:var(--muted2);line-height:1.7;
  margin-bottom:0.9rem;padding-bottom:0.9rem;
  border-bottom:1px solid var(--border2);
}
.svc-overlay ul{list-style:none}
.svc-overlay ul li{
  font-size:12px;color:var(--textd);padding:4px 0;
  border-bottom:1px solid rgba(90,179,245,0.07);
  display:flex;align-items:flex-start;gap:8px;line-height:1.5;
}
.svc-overlay ul li::before{content:'→';color:var(--blue2);font-size:10px;flex-shrink:0;margin-top:2px}
.svc-overlay-cta{
  margin-top:auto;padding-top:0.85rem;
  font-size:11px;color:var(--blue2);letter-spacing:0.08em;
  text-transform:uppercase;display:flex;align-items:center;gap:6px;cursor:pointer;
}
.svc-overlay-cta::after{content:'→';transition:transform 0.2s}
.svc-overlay:hover .svc-overlay-cta::after{transform:translateX(4px)}
.svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);margin-top:3rem}
.svc{
  background:var(--bg2);padding:2rem;
  position:relative;overflow:hidden;transition:background 0.25s;
  display:flex;flex-direction:column;
}
.svc:hover{background:var(--bg3)}
.svc::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--blue),transparent);
  transform:scaleX(0);transform-origin:left;transition:transform 0.35s;
}
.svc:hover::before{transform:scaleX(1)}
.svc-ico{margin-bottom:1.25rem}
.svc-ico svg{width:22px;height:22px;stroke:var(--blue2);fill:none;stroke-width:1.5}
.svc h3{font-size:1rem;margin-bottom:0.6rem}
.svc p{font-size:13.5px;color:var(--muted2);line-height:1.75;margin-bottom:1rem;flex:1}
.svc-list{list-style:none;margin-top:auto}
.svc-list li{
  font-size:12.5px;color:var(--muted);padding:5px 0;
  border-top:1px solid rgba(74,163,240,0.08);
  display:flex;align-items:center;gap:6px;
}
.svc-list li::before{content:'';width:3px;height:3px;background:var(--blue2);border-radius:50%;flex-shrink:0}

/* ── MISSION BANNER ── */
.mission-banner{
  background:linear-gradient(135deg,rgba(36,120,200,0.12) 0%,rgba(90,179,245,0.06) 100%);
  border-top:1px solid var(--border2);border-bottom:1px solid var(--border2);
  padding:3.5rem 3.5rem;text-align:center;
}
.mission-banner-label{font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--blue2);margin-bottom:1.25rem;font-weight:500}
.mission-stmt{
  font-family:'DM Sans',sans-serif;
  font-size:clamp(1.3rem,2.4vw,2rem);font-weight:500;
  color:var(--textd);line-height:1.5;max-width:820px;margin:0 auto 1.5rem;
  letter-spacing:-0.01em;
}
.mission-stmt em{color:var(--blue2);font-style:normal}
.mission-pillars{
  display:flex;align-items:center;justify-content:center;gap:0;
  flex-wrap:wrap;margin-top:1.75rem;border:1px solid var(--border);
  max-width:680px;margin-left:auto;margin-right:auto;
}
.mpillar{
  padding:0.85rem 2rem;font-size:11px;letter-spacing:0.14em;
  text-transform:uppercase;color:var(--muted2);
  border-right:1px solid var(--border);flex:1;text-align:center;
  white-space:nowrap;
}
.mpillar:last-child{border-right:none}
.mpillar strong{display:block;color:var(--blue2);font-size:13px;font-weight:500;letter-spacing:0.05em;margin-bottom:3px}

/* ── VISION ── */
.vision-intro{display:grid;grid-template-columns:1fr 1fr;gap:5rem;margin-bottom:3rem;align-items:end}
.vision-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border)}
.vcard{
  background:var(--bg);padding:2.25rem;
  position:relative;overflow:hidden;transition:background 0.25s;
}
.vcard:hover{background:var(--bg3)}
.vcard-n{
  font-family:'DM Sans',sans-serif;font-size:3rem;font-weight:500;
  color:rgba(74,163,240,0.07);position:absolute;
  top:1rem;right:1.5rem;line-height:1;pointer-events:none;
}
.vcard-ico{
  width:40px;height:40px;
  border:1px solid var(--border2);
  display:flex;align-items:center;justify-content:center;margin-bottom:1.4rem;
}
.vcard-ico svg{width:17px;height:17px;stroke:var(--blue2);fill:none;stroke-width:1.5}
.vcard h3{font-size:1rem;margin-bottom:0.6rem}
.vcard p{font-size:13.5px;color:var(--muted2);line-height:1.75}
.vision-cta-bar{
  background:var(--bg3);border:1px solid var(--border);
  padding:2rem 2.5rem;margin-top:2.5rem;
  display:flex;align-items:center;justify-content:space-between;gap:2rem;
}
.vision-cta-bar p{font-size:14px;color:var(--muted2);max-width:540px;line-height:1.75}

/* ── LEADERSHIP ── */
.team-intro{max-width:660px;margin-bottom:3rem}
.team-intro p{font-size:1rem;color:var(--muted2);line-height:1.85;margin-top:1rem}
.profile-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);margin-bottom:3rem}
@media(max-width:960px){.profile-grid{background:transparent;gap:1px}}
/* ── TEAM CARDS — real people ── */
.pcard{background:var(--bg2);padding:2.25rem;transition:background 0.25s}
.pcard:hover{background:var(--bg3)}
.pavatar{
  width:140px;height:140px;border-radius:50%;
  background:linear-gradient(135deg,#1A4A7A,#2E6DA8);
  display:flex;align-items:center;justify-content:center;
  font-size:34px;font-weight:700;color:#EBF3FA;
  margin-bottom:1.25rem;border:2px solid var(--border2);
  font-family:'DM Sans',sans-serif;letter-spacing:0.05em;
  flex-shrink:0;overflow:hidden;cursor:pointer;
  transition:transform 0.3s ease,border-color 0.3s ease,box-shadow 0.3s ease;
}
.pavatar:hover{
  transform:scale(1.12);
  border-color:var(--blue2);
  box-shadow:0 8px 28px rgba(46,109,168,0.35);
}
.pavatar img{width:100%;height:100%;object-fit:cover;border-radius:50%}
.pavatar-hint{
  font-size:10px;letter-spacing:0.1em;text-transform:uppercase;
  color:var(--muted);margin-top:-0.9rem;margin-bottom:1.2rem;
}
.pavatar-open{
  width:88px;height:88px;border-radius:50%;
  background:transparent;
  border:2px dashed var(--border2);
  display:flex;align-items:center;justify-content:center;
  font-size:28px;color:var(--muted);
  margin-bottom:1.25rem;flex-shrink:0;
}
.p-name{font-size:1.05rem;font-weight:600;color:var(--textd);margin-bottom:0.25rem}
.p-role{font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:var(--blue2);font-weight:600;margin-bottom:0.2rem}
.p-title{font-size:12px;color:var(--muted2);margin-bottom:0.85rem}
.p-desc{font-size:13px;color:var(--muted2);line-height:1.75;margin-bottom:1rem}
.p-education{font-size:11px;color:var(--muted);margin-bottom:1rem;font-style:italic}
.ptags{display:flex;flex-wrap:wrap;gap:0.4rem;margin-top:auto}
.ptag{font-size:10px;letter-spacing:0.08em;text-transform:uppercase;
  padding:3px 10px;border:1px solid var(--border2);color:var(--blue2);white-space:nowrap}
.expertise-cols{display:grid;grid-template-columns:1fr 1fr;gap:0 3rem}
.exp-item{
  display:flex;align-items:center;gap:0.75rem;
  font-size:13.5px;color:var(--muted2);
  padding:0.75rem 0;border-bottom:1px solid var(--border);
}
.exp-dot{width:6px;height:6px;background:var(--blue2);border-radius:50%;flex-shrink:0}

/* ── APPROACH ── */
.approach-row{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);margin-top:3rem}
.astep{background:var(--bg2);padding:2.25rem;transition:background 0.25s}
.astep:hover{background:var(--bg3)}
.astep-n{
  font-family:'DM Sans',sans-serif;font-size:3rem;font-weight:500;
  color:rgba(74,163,240,0.1);line-height:1;margin-bottom:1.1rem;
}
.astep h3{font-size:1rem;margin-bottom:0.5rem}
.astep p{font-size:13.5px;color:var(--muted2);line-height:1.75}

/* ── CONTACT ── */
.contact-cols{display:grid;grid-template-columns:1fr 1.2fr;gap:5rem;margin-top:3.5rem}
.cinfo-lead{font-size:1.05rem;color:var(--muted2);line-height:1.85;margin-bottom:2.5rem}
.crows{display:flex;flex-direction:column;gap:1.1rem}
.crow{display:flex;align-items:center;gap:1rem}
.cico{width:38px;height:38px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.cico svg{width:15px;height:15px;stroke:var(--blue2);fill:none;stroke-width:1.5}
.clbl{font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);margin-bottom:3px}
.cval{font-size:14px;color:var(--text)}
.cform{display:flex;flex-direction:column;gap:1rem}
