];

function fmtPrice(p){
  if(p>=1000)return p.toLocaleString('en',{maximumFractionDigits:1});
  if(p>=100)return p.toFixed(2);
  return p.toFixed(4);
}
function fmtChg(c,p){
  const pct=(c/p*100);
  const sign=c>=0?'+':'';
  return `${sign}${pct.toFixed(2)}%`;
}

function buildTicker(data){
  const track=document.getElementById('tickerTrack');
  const doubled=[...data,...data];
  track.innerHTML=doubled.map(d=>{
    const dir=d.chg>0?'up':d.chg<0?'down':'flat';
    const chgStr=fmtChg(d.chg,d.price);
    return `<span class="ticker-item">
      <span class="ticker-sym">${d.sym}</span>
      <span class="ticker-price">${fmtPrice(d.price)}</span>
      <span class="ticker-change ${dir}">${chgStr}</span>
    </span>`;
  }).join('');

  /* Smooth CSS animation */
  const single=data.length;
  const itemW=180;
  const totalW=single*itemW;
  track.style.cssText=`
    display:inline-flex;white-space:nowrap;
    animation:tickerScroll ${single*4}s linear infinite;
  `;
  const style=document.createElement('style');
  style.textContent=`
    @keyframes tickerScroll{
      0%{transform:translateX(0)}
      100%{transform:translateX(-${totalW}px)}
    }
    .market-ticker:hover #tickerTrack{animation-play-state:paused}
  `;
  document.head.appendChild(style);
}

async function fetchFinnhub(){
  if(FINNHUB_KEY==='YOUR_FINNHUB_KEY'){
    /* Simulate realistic live-ish data with small random drift */
    const live=SIMULATED.map(d=>{
      const drift=(Math.random()-0.49)*0.001*d.price;
      return {sym:d.sym,price:+(d.price+drift).toFixed(6),chg:d.chg+drift};
    });
    buildTicker(live);
    return;
  }
  try{
    const results=await Promise.all(SYMBOLS.map(async s=>{
      const r=await fetch(`https://finnhub.io/api/v1/quote?symbol=${encodeURIComponent(s.finnhub)}&token=${FINNHUB_KEY}`);
      const j=await r.json();
      return {sym:s.sym,price:j.c||0,chg:(j.c||0)-(j.pc||0)};
    }));
    buildTicker(results.filter(r=>r.price>0));
  }catch(e){
    buildTicker(SIMULATED);
  }
}

fetchFinnhub();
setInterval(fetchFinnhub, 30000); /* refresh every 30s */
